# ==============================
# FOREX RADAR AI - Configuração
# ==============================

# App
APP_NAME=Forex Radar AI
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-this-secret-key-in-production
API_V1_PREFIX=/api/v1

# Banco de Dados
POSTGRES_USER=forexradar
POSTGRES_PASSWORD=forexradar_secret
POSTGRES_DB=forex_radar_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://forexradar:forexradar_secret@db:5432/forex_radar_ai

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Mercado
SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD,NZDUSD,USDCAD,USDCHF,EURJPY,GBPJPY,XAUUSD
TIMEFRAMES=M1,M5,M15,H1
DATA_PROVIDER=simulated
# Opções: simulated | twelvedata (OANDA/MT5 exigem implementar novo provider)
#
# Para dados REAIS via TwelveData (https://twelvedata.com/pricing):
#   1. Crie uma conta gratuita e gere sua API key
#   2. DATA_PROVIDER=twelvedata
#   3. MARKET_DATA_API_KEY=sua_chave_aqui
#
# O plano gratuito da TwelveData permite 8 requisições/min e 800/dia. Com os
# 10 pares padrão x 4 timeframes, isso estoura rápido. Recomendado no plano
# free: reduza SYMBOLS (ex.: só EURUSD,GBPUSD,USDJPY,XAUUSD) e/ou TIMEFRAMES
# (ex.: só M15,H1). O provider já tem cache + rate limiting internos, mas não
# faz milagre além da cota da sua conta.
MARKET_DATA_API_KEY=

# Estratégia / Gestão de Risco
RISK_PER_TRADE_PERCENT=1.0
MIN_RISK_REWARD=2.0
MAX_OPERATIONS_PER_SYMBOL_PER_DAY=3
IQS_MIN_SIGNAL=90
IQS_MIN_PREPARING=80

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
